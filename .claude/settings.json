{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": ".claude/hooks/check-secrets.sh",
            "timeout": 15,
            "statusMessage": "ステージ済み差分の機密情報チェック..."
          }
        ]
      }
    ]
  }
}
